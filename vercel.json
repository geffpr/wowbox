{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/send-scheduled",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/process-payouts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/process-boost-notifications",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/keep-alive",
      "schedule": "0 6 */3 * *"
    },
    {
      "path": "/api/paystack-reminder",
      "schedule": "0 7 * * 1"
    }
  ]
}
